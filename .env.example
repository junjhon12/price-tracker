# GitHub personal access token for the github MCP
# Create one at: https://github.com/settings/tokens (classic token with repo scope is fine for tonight)
# Or leave blank and use `gh auth login`, the github MCP will fall back to gh CLI credentials.
GITHUB_TOKEN=

# Optional: Anthropic API key if you want to call Claude from your project code
# (Project A does not need this. Project B only needs it if you add AI features.)
ANTHROPIC_API_KEY=
